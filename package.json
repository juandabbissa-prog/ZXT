{
  "name": "re-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.15",
  "workspaces": ["apps/*", "packages/*", "workers"],
  "scripts": {
    "dev": "bun --filter @re-agent/web dev",
    "build": "bun --filter '*' run build",
    "lint": "bun --filter '*' run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun --filter '*' run test",
    "typecheck": "bun --filter '*' run typecheck",
    "db:generate": "bun --filter @re-agent/database prisma:generate",
    "db:validate": "bun --filter @re-agent/database prisma:validate",
    "db:migrate": "bun --filter @re-agent/database prisma:migrate",
    "db:seed": "bun --filter @re-agent/database prisma:seed",
    "db:reset": "bun --filter @re-agent/database prisma:reset",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose down --remove-orphans && docker compose build --no-cache && docker compose up -d",
    "docker:reset-db": "docker compose down --volumes --remove-orphans && docker compose up --build -d",
    "docker:test": "docker compose run --rm web bun run test",
    "feature:create": "bun run scripts/create-feature.ts",
    "architecture:check": "bun run scripts/check-service-repository-architecture.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
